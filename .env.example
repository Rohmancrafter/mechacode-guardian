# MechaCode Guardian — Environment Variables Template
#
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is excluded by .gitignore.
#
# Required variables are marked (required).
# Optional variables have defaults shown below.
#
# See docs/ARCHITECTURE.md §8 and §10 for credential source guidance.

# -------------------------------------------------------------------------
# # Google AI — gemini-embedding-001 embeddings + Gemini fallback LLM (UD-03)
# Obtain at: https://aistudio.google.com/app/apikey
# -------------------------------------------------------------------------
GOOGLE_AI_API_KEY=                          # (required)

# -------------------------------------------------------------------------
# watsonx.ai — optional IBM Granite integration
# Leave these empty until IBM Cloud access is available.
# Obtain at: https://dataplatform.cloud.ibm.com/
# -------------------------------------------------------------------------
WX_API_KEY=                                 # optional
WX_PROJECT_ID=                              # optional
WX_URL=https://us-south.ml.cloud.ibm.com   # optional

# -------------------------------------------------------------------------
# Astra DB — vector store (ARCHITECTURE.md §1.3)
# Collections used:
#   mechacode_guardian_kb   (knowledge base — 3072-dim cosine)
#   diagnosis_reports       (session reports)
# Capstone collection must NOT be modified.
# Obtain at: https://astra.datastax.com/
# -------------------------------------------------------------------------
ASTRA_DB_TOKEN=                             # (required) Application Token (AstraCS:...)
ASTRA_DB_API_ENDPOINT=                      # (required) https://<db-id>-<region>.apps.astra.datastax.com
ASTRA_DB_KEYSPACE=default_keyspace          # (optional)

# -------------------------------------------------------------------------
# Application settings (optional — defaults shown)
# -------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173          # Comma-separated list of allowed frontend origins

# -------------------------------------------------------------------------
# Collection name overrides (optional — do not change unless re-ingesting)
# -------------------------------------------------------------------------
# KB_COLLECTION=mechacode_guardian_kb
# REPORTS_COLLECTION=diagnosis_reports
